# Project Identity
PROJECT_NAME=name
COMPOSE_PROJECT_NAME=name

# Ports
HTTP_PORT=8080
HTTPS_PORT=8443
MAIL_UI_PORT=8081
DB_PORT=3306

# Database Credentials
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

# Versions
MYSQL_VERSION=8.0
PHP_VERSION=fpm

# Proxy
SITE_ADDRESS=http://localhost:8080

# Generate these with: curl https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY=your_key_here
SECURE_AUTH_KEY=your_key_here
LOGGED_IN_KEY=your_key_here
NONCE_KEY=your_key_here
AUTH_SALT=your_salt_here
SECURE_AUTH_SALT=your_salt_here
LOGGED_IN_SALT=your_salt_here
NONCE_SALT=your_salt_here